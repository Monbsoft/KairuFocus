@page "/tasks/{Id:guid}"
@attribute [Authorize]
@using KairuFocus.Web.Services
@inject TaskApiClient Api
@inject NavigationManager Nav
@inject MarkdownService MarkdownSvc

<PageTitle>@(task?.Title ?? "Tâche") — KairuFocus</PageTitle>

<div class="kf-te">
    @if (notFound)
    {
        <Alert Tone="warning">Tâche introuvable.</Alert>
        <div class="kf-te__actions">
            <Button Variant="secondary" OnClick="GoBack">Retour</Button>
        </div>
    }
    else if (task is null)
    {
        <p style="color: var(--text-muted);">Chargement…</p>
    }
    else
    {
        <div class="kf-te__back">
            <Button Variant="ghost" Size="sm" OnClick="GoBack">← Retour</Button>
        </div>

        <div class="kf-te__head">
            <h1 class="kf-te__title">@task.Title</h1>
            <Badge Status="@task.Status" />
            @if (!string.IsNullOrWhiteSpace(task.JiraTicketKey))
            {
                <Badge Variant="solid">@task.JiraTicketKey</Badge>
            }
        </div>

        @if (task.Tags is { Count: > 0 })
        {
            <div class="kf-te__tags">
                @foreach (var tag in task.Tags)
                {
                    <Tag Hash ChildContent="@tag" />
                }
            </div>
        }

        <Card Class="kf-detailcard">
            @if (string.IsNullOrWhiteSpace(task.Description))
            {
                <p class="kf-md__empty">Aucune description.</p>
            }
            else
            {
                <div class="kf-md" style="border: none; padding: 0; background: transparent; min-height: 80px;">
                    @((MarkupString)MarkdownSvc.Render(task.Description))
                </div>
            }
        </Card>

        <div class="kf-te__actions">
            @if (task.Status != "Done")
            {
                <Button Variant="primary" OnClick="GoToEdit">Modifier</Button>
            }
            <Button Variant="secondary" OnClick="GoBack">Retour</Button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private TaskDto? task;
    private bool notFound;

    protected override async Task OnInitializedAsync()
    {
        task = await Api.GetByIdAsync(Id);
        notFound = task is null;
    }

    private void GoToEdit() => Nav.NavigateTo($"/tasks/{Id}/edit");

    private void GoBack() => Nav.NavigateTo("/tasks");
}
