@page "/journal"
@attribute [Authorize]
@using KairuFocus.Web.Services
@using KairuFocus.Web.Helpers
@using KairuFocus.Web.Components.Design
@inject JournalApiClient Api

<div class="notebook">

    <div class="notebook-header">
        <button class="nb-nav-btn" @onclick="PreviousDay" aria-label="Jour précédent">←</button>
        <div class="notebook-title">
            <span class="notebook-day">@GetDayName()</span>
            <span class="notebook-date">@GetDateFull()</span>
        </div>
        <button class="nb-nav-btn" @onclick="NextDay" disabled="@IsToday" aria-label="Jour suivant">→</button>
    </div>

    <div class="notebook-body">

        @if (errorMessage is not null)
        {
            <Alert Tone="danger">@errorMessage</Alert>
        }

        @if (entries is null)
        {
            <p class="text-muted px-4 pt-3 fst-italic">Chargement…</p>
        }
        else if (entries.Count == 0)
        {
            <div class="notebook-empty">
                <div class="notebook-empty-icon" aria-hidden="true">📓</div>
                <p class="text-muted fst-italic mb-1">Aucune activité enregistrée ce jour.</p>
                @if (IsToday)
                {
                    <p class="text-muted small">Démarrez un sprint Pomodoro pour voir apparaître vos entrées ici.</p>
                }
            </div>
        }
        else
        {
            <div class="notebook-timeline">
                @foreach (var entry in entries)
                {
                    <div class="nb-entry nb-@JournalEntryMeta.GetVariant(entry.EventType)">
                        <div class="nb-time">@entry.OccurredAt.ToLocalTime().ToString("HH:mm")</div>
                        <div class="nb-dot-col">
                            <div class="nb-dot"></div>
                            <div class="nb-line"></div>
                        </div>
                        <div class="nb-content">
                            <div class="nb-event">
                                <span class="nb-icon" aria-hidden="true">@JournalEntryMeta.GetIcon(entry.EventType)</span>
                                <span class="nb-label">@JournalEntryMeta.GetLabel(entry)</span>
                            </div>

                            @if (entry.LinkedTasks.Count > 0)
                            {
                                <div class="nb-tasks">
                                    <span class="nb-tasks-header">Tâches travaillées</span>
                                    <ul class="nb-tasks-list">
                                        @foreach (var task in entry.LinkedTasks)
                                        {
                                            <li>
                                                <span>@task.Title</span>
                                                @foreach (var tag in task.Tags)
                                                {
                                                    <Tag Hash ChildContent="@tag" />
                                                }
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }

                            @foreach (var comment in entry.Comments)
                            {
                                <div class="nb-comment">
                                    @if (editingCommentId == comment.Id)
                                    {
                                        <textarea class="form-control form-control-sm mb-1"
                                                  @bind="editCommentText"
                                                  @bind:event="oninput"
                                                  rows="2"></textarea>
                                        <div class="d-flex gap-1 mt-1">
                                            <Button Variant="primary" Size="sm" OnClick="() => SaveEditComment(entry.Id, comment.Id)">✓ Enregistrer</Button>
                                            <Button Variant="ghost" Size="sm" OnClick="CancelEditComment">Annuler</Button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="nb-comment-body">
                                            <span class="nb-comment-text">✏️ @comment.Text</span>
                                            <span class="nb-comment-actions">
                                                <IconButton Label="Modifier ce commentaire"
                                                            Tone="primary"
                                                            Size="sm"
                                                            OnClick="() => StartEditComment(comment)">✎</IconButton>
                                                <IconButton Label="Supprimer ce commentaire"
                                                            Tone="danger"
                                                            Size="sm"
                                                            OnClick="() => DeleteComment(entry.Id, comment.Id)">✕</IconButton>
                                            </span>
                                        </div>
                                    }
                                </div>
                            }

                            @if (JournalEntryMeta.CanAddComment(entry.EventType))
                            {
                                @if (addingCommentForEntryId == entry.Id)
                                {
                                    <div class="nb-add-comment mt-2">
                                        <textarea class="form-control form-control-sm mb-1"
                                                  placeholder="Votre note…"
                                                  @bind="newCommentText"
                                                  @bind:event="oninput"
                                                  rows="2"></textarea>
                                        <div class="d-flex gap-1">
                                            <Button Variant="primary" Size="sm" OnClick="() => SaveAddComment(entry.Id)">Ajouter</Button>
                                            <Button Variant="ghost" Size="sm" OnClick="CancelAddComment">Annuler</Button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button class="nb-add-btn" @onclick="() => StartAddComment(entry.Id)">+ note</button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<JournalEntryDto>? entries;
    private string? errorMessage;

    private Guid? addingCommentForEntryId;
    private string newCommentText = string.Empty;

    private Guid? editingCommentId;
    private string editCommentText = string.Empty;

    private DateOnly _displayDate = DateOnly.FromDateTime(DateTime.Today);
    private bool IsToday => _displayDate == DateOnly.FromDateTime(DateTime.Today);

    private static readonly System.Globalization.CultureInfo Fr = new("fr-FR");

    protected override async Task OnInitializedAsync() =>
        await LoadEntries();

    private async Task LoadEntries()
    {
        try
        {
            entries = IsToday
                ? await Api.GetTodayEntriesAsync()
                : await Api.GetEntriesByDateAsync(_displayDate);
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement : {ex.Message}";
        }
    }

    // ── Navigation ────────────────────────────────────────

    private async Task PreviousDay()
    {
        _displayDate = _displayDate.AddDays(-1);
        await LoadEntries();
    }

    private async Task NextDay()
    {
        if (!IsToday)
        {
            _displayDate = _displayDate.AddDays(1);
            await LoadEntries();
        }
    }

    // ── Helpers date ──────────────────────────────────────

    private string GetDayName() =>
        _displayDate.ToString("dddd", Fr).ToUpperInvariant();

    private string GetDateFull() =>
        _displayDate.ToString("d MMMM yyyy", Fr);

    // ── Actions commentaires ──────────────────────────────

    private void StartAddComment(Guid entryId)
    {
        addingCommentForEntryId = entryId;
        newCommentText = string.Empty;
    }

    private async Task SaveAddComment(Guid entryId)
    {
        if (string.IsNullOrWhiteSpace(newCommentText)) return;
        try
        {
            await Api.AddCommentAsync(entryId, newCommentText);
            addingCommentForEntryId = null;
            newCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de l'ajout : {ex.Message}"; }
    }

    private void CancelAddComment()
    {
        addingCommentForEntryId = null;
        newCommentText = string.Empty;
    }

    private void StartEditComment(JournalCommentDto comment)
    {
        editingCommentId = comment.Id;
        editCommentText = comment.Text;
    }

    private async Task SaveEditComment(Guid entryId, Guid commentId)
    {
        if (string.IsNullOrWhiteSpace(editCommentText)) return;
        try
        {
            await Api.UpdateCommentAsync(entryId, commentId, editCommentText);
            editingCommentId = null;
            editCommentText = string.Empty;
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de la modification : {ex.Message}"; }
    }

    private void CancelEditComment()
    {
        editingCommentId = null;
        editCommentText = string.Empty;
    }

    private async Task DeleteComment(Guid entryId, Guid commentId)
    {
        try
        {
            await Api.DeleteCommentAsync(entryId, commentId);
            await LoadEntries();
        }
        catch (Exception ex) { errorMessage = $"Erreur lors de la suppression : {ex.Message}"; }
    }
}
