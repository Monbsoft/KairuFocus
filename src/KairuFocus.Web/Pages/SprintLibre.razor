@page "/pomodoro/libre"
@attribute [Authorize]
@using KairuFocus.Web.Services
@using KairuFocus.Web.Components.Design
@inject PomodoroApiClient PomodoroApi
@inject TaskApiClient TaskApi
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="kf-sl">

    <!-- En-tête -->
    <div class="kf-sl__head">
        <Button Variant="ghost" Size="sm" OnClick='() => Nav.NavigateTo("/pomodoro")'>
            ← Retour
        </Button>
        <h1>Sprint libre</h1>
    </div>

    @if (!_loaded)
    {
        <p class="text-muted">Chargement…</p>
    }
    else
    {
        <!-- Configuration (visible seulement avant démarrage) -->
        @if (!_running)
        {
            <div class="kf-sl__config">
                <div class="kf-sl__field">
                    <label class="kf-sl__label" for="sl-note">Note (optionnelle)</label>
                    <input id="sl-note"
                           class="kf-input"
                           placeholder="Ex. daily un peu long, bloqué sur X…"
                           @bind="_note"
                           @bind:event="oninput" />
                </div>
                <div class="kf-sl__field">
                    <label class="kf-sl__label" for="sl-task">Tâche liée (optionnel)</label>
                    <select id="sl-task" class="kf-select" @bind="_selectedTaskId">
                        <option value="">— Aucune tâche —</option>
                        @foreach (var task in _availableTasks)
                        {
                            <option value="@task.Id">@task.Title</option>
                        }
                    </select>
                </div>
            </div>
        }

        <!-- Chronomètre count-up -->
        <div class="kf-sl__clock @(_running ? "kf-sl__clock--running" : "kf-sl__clock--idle")">
            @TimeDisplay
        </div>

        @if (_running)
        {
            <div class="kf-sl__status">
                Sprint #@(_todaySprints.Count + 1) en cours
            </div>
        }

        <!-- Boutons de contrôle -->
        <div class="kf-sl__controls">
            @if (!_running)
            {
                <Button Variant="primary" Size="lg" OnClick="StartSprint">▶ Démarrer</Button>
            }
            else
            {
                <Button Variant="primary" Size="lg" OnClick="FinishSprint">✓ Terminer</Button>
                <Button Variant="secondary" Size="lg" OnClick="InterruptSprint">⏹ Interrompre</Button>
            }
        </div>

        <!-- Résultat après fin de sprint (Peak-End) -->
        @if (_lastCompleted is not null)
        {
            var dur = TimeSpan.FromSeconds(_lastCompleted.DurationSeconds ?? 0);
            var outcomeLabel = _lastCompleted.Status == "Completed" ? "Terminé" : "Interrompu";
            <Alert Tone="success">
                Sprint enregistré —
                <span class="kf-sl__dur">@dur.ToString(@"hh\:mm\:ss")</span>
                — @outcomeLabel
            </Alert>
        }

        <!-- Erreur -->
        @if (_errorMessage is not null)
        {
            <Alert Tone="danger">@_errorMessage</Alert>
        }

        <!-- Historique du jour -->
        @if (_todaySprints.Count > 0)
        {
            <div class="kf-sl__history">
                <h2>Sprints du jour (@_todaySprints.Count)</h2>
                @foreach (var sprint in _todaySprints)
                {
                    var dur = TimeSpan.FromSeconds(sprint.DurationSeconds ?? 0);
                    var linkedTask = sprint.LinkedTaskIds.Count > 0
                        ? _availableTasks.FirstOrDefault(t => t.Id == sprint.LinkedTaskIds[0])
                        : null;
                    <div class="kf-sl__row">
                        <span class="kf-sl__rowtask">
                            @if (linkedTask is not null)
                            {
                                <span>🔗 @linkedTask.Title</span>
                            }
                            else
                            {
                                <span class="kf-sl__rowtask--empty">Sans tâche</span>
                            }
                        </span>
                        <span class="kf-sl__rowmeta">
                            <span class="kf-sl__rowdur">@dur.ToString(@"hh\:mm\:ss")</span>
                            @if (sprint.Status == "Completed")
                            {
                                <Badge Status="Done" />
                            }
                            else
                            {
                                <Badge Variant="inprogress"><span>Interrompu</span></Badge>
                            }
                        </span>
                    </div>
                }
            </div>
        }
    }

</div>

@code {
    // ── État ──────────────────────────────────────────────────────────────
    private bool _loaded;
    private bool _running;
    private string _note = string.Empty;
    private string _selectedTaskId = string.Empty;
    private Guid? _activeSessionId;
    private int _elapsedSeconds;
    private List<PomodoroSessionDto> _todaySprints = [];
    private List<TaskDto> _availableTasks = [];
    private PomodoroSessionDto? _lastCompleted;
    private string? _errorMessage;
    private CancellationTokenSource? _timerCts;

    // ── Computed ──────────────────────────────────────────────────────────
    private string TimeDisplay =>
        $"{_elapsedSeconds / 3600:D2}:{_elapsedSeconds % 3600 / 60:D2}:{_elapsedSeconds % 60:D2}";

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _todaySprints = await PomodoroApi.GetTodaySprintSessionsAsync();
        _availableTasks = (await TaskApi.GetAllAsync())
            .Where(t => t.Status != "Done")
            .ToList();
        _loaded = true;
    }

    public async ValueTask DisposeAsync()
    {
        await StopTimer();
    }

    // ── Actions ───────────────────────────────────────────────────────────
    private async Task StartSprint()
    {
        _errorMessage = null;
        _lastCompleted = null;

        var note = _note.Trim() is { Length: > 0 } n ? n : null;
        var session = await PomodoroApi.StartFreeSprintAsync(note);
        if (session is null)
        {
            _errorMessage = "Impossible de démarrer le sprint.";
            return;
        }

        _activeSessionId = session.Id;
        _elapsedSeconds = 0;
        _running = true;

        if (Guid.TryParse(_selectedTaskId, out var taskGuid))
            await PomodoroApi.LinkTaskAsync(taskGuid);

        await StartTimerLoop();
    }

    private async Task FinishSprint()
    {
        await StopTimer();
        _running = false;
        var ok = await PomodoroApi.CompleteSessionAsync();
        if (!ok) { _errorMessage = "Impossible de terminer le sprint."; return; }
        await RefreshAfterSprint();
    }

    private async Task InterruptSprint()
    {
        await StopTimer();
        _running = false;
        var ok = await PomodoroApi.InterruptSessionAsync();
        if (!ok) { _errorMessage = "Impossible d'interrompre le sprint."; return; }
        await RefreshAfterSprint();
    }

    private async Task RefreshAfterSprint()
    {
        _errorMessage = null;
        _note = string.Empty;
        _selectedTaskId = string.Empty;
        _activeSessionId = null;
        _todaySprints = await PomodoroApi.GetTodaySprintSessionsAsync();
        _lastCompleted = _todaySprints.LastOrDefault();
        _elapsedSeconds = 0;
        _availableTasks = (await TaskApi.GetAllAsync())
            .Where(t => t.Status != "Done")
            .ToList();
    }

    // ── Timer internals ───────────────────────────────────────────────────
    private async Task StartTimerLoop()
    {
        await StopTimer();
        _timerCts = new CancellationTokenSource();
        var token = _timerCts.Token;

        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            try
            {
                while (await timer.WaitForNextTickAsync(token))
                {
                    _elapsedSeconds++;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        }, token);
    }

    private async Task StopTimer()
    {
        if (_timerCts is not null)
        {
            await _timerCts.CancelAsync();
            _timerCts.Dispose();
            _timerCts = null;
        }
    }
}
