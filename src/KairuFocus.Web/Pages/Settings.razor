@page "/settings"
@attribute [Authorize]
@using KairuFocus.Web.Services
@inject PomodoroApiClient PomodoroApi
@inject SettingsApiClient SettingsApi
@inject McpTokenService McpTokenApi
@inject IJSRuntime JSRuntime
@inject ISoundService SoundService

<h1 class="kf-settings__title">⚙ Paramètres</h1>

@if (!_loaded)
{
    <!-- Skeleton Doherty — évite le blank-screen pendant le chargement -->
    <div class="kf-settings-skel" aria-busy="true" aria-label="Chargement des paramètres">
        <div class="kf-skel kf-settings-skel__card"></div>
        <div class="kf-skel kf-settings-skel__card"></div>
        <div class="kf-skel kf-settings-skel__card"></div>
        <div class="kf-skel kf-settings-skel__card"></div>
    </div>
}
else
{
    <div class="kf-settings">

        <!-- ── Section Thème ─────────────────────────────────────────── -->
        <Card class="kf-section">
            <h2 class="kf-section__title">🎨 Thème</h2>
            <div class="kf-field-row">
                <label class="kf-field-label" for="themeSelect">Préférence de thème</label>
                <select id="themeSelect" class="kf-select" @bind="_selectedTheme" @bind:after="OnThemeChanged">
                    <option value="Light">☀️ Clair</option>
                    <option value="Dark">🌙 Sombre</option>
                    <option value="System">⚙️ Système</option>
                </select>
                <div class="kf-hint">Le thème est appliqué immédiatement et sauvegardé.</div>
            </div>
        </Card>

        <!-- ── Section Sonnerie ──────────────────────────────────────── -->
        <Card class="kf-section">
            <h2 class="kf-section__title">🔔 Sonnerie Pomodoro</h2>
            <div class="kf-inline">
                <div class="kf-inline-grow">
                    <label class="kf-field-label" for="ringtoneSelect">Son de fin de session</label>
                    <select id="ringtoneSelect" class="kf-select" @bind="_selectedRingtone" @bind:after="OnRingtoneChanged">
                        <option value="None">🔇 Aucun son</option>
                        <option value="AlarmClock">⏰ Réveil</option>
                        <option value="Bird">🐦 Oiseau</option>
                    </select>
                </div>
                <Button Variant="secondary"
                        Disabled="@(_selectedRingtone == "None")"
                        OnClick="PreviewRingtone">▶ Tester</Button>
            </div>
            <div class="kf-hint">Joué automatiquement à la fin de chaque sprint ou pause.</div>
        </Card>

        <!-- ── Section Token MCP ─────────────────────────────────────── -->
        <Card class="kf-section">
            <h2 class="kf-section__title">Token MCP</h2>

            @if (_mcpLoading)
            {
                <p class="kf-mcp-empty">Chargement du statut…</p>
            }
            else if (_mcpLoadError)
            {
                <Alert Tone="danger">Impossible de charger le statut du token. Veuillez rafraîchir la page.</Alert>
            }
            else if (_mcpHasToken)
            {
                <div class="kf-mcp-status">
                    <Badge Variant="done">Actif</Badge>
                    <span>Expire le <strong>@(_mcpExpiresAt?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")</strong></span>
                </div>
                <div class="kf-actions" style="margin-top: 0">
                    <Button Variant="secondary"
                            Disabled="@_mcpActionInProgress"
                            OnClick="RegenerateToken">@(_mcpActionInProgress ? "En cours…" : "Régénérer")</Button>
                    <Button Variant="danger"
                            Disabled="@_mcpActionInProgress"
                            OnClick="RevokeToken">@(_mcpActionInProgress ? "En cours…" : "Révoquer")</Button>
                </div>
            }
            else
            {
                <p class="kf-mcp-empty">Aucun token MCP configuré.</p>
                <Button Variant="primary"
                        Disabled="@_mcpActionInProgress"
                        OnClick="GenerateToken">@(_mcpActionInProgress ? "Génération…" : "Générer un token")</Button>
            }

            @if (_mcpError is not null)
            {
                <div class="kf-mcp-error">
                    <Alert Tone="danger">@_mcpError</Alert>
                </div>
            }
        </Card>

        <!-- ── Modal Token MCP (one-shot) ───────────────────────────── -->
        @if (_mcpRawToken is not null)
        {
            <div class="modal d-block kf-modal-scrim"
                 tabindex="-1"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="mcpTokenModalTitle">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content kf-modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="mcpTokenModalTitle">Token MCP généré</h5>
                        </div>
                        <div class="modal-body">
                            <Alert Tone="warning">
                                <strong>Attention :</strong> Ce token ne sera plus affiché. Copiez-le maintenant.
                            </Alert>
                            <div style="margin-top: 0.75rem;">
                                <label class="kf-field-label" for="mcpTokenValue">Token</label>
                                <div class="kf-inline">
                                    <input id="mcpTokenValue"
                                           type="text"
                                           class="kf-token-input"
                                           readonly
                                           value="@_mcpRawToken" />
                                    <Button Variant="secondary"
                                            OnClick="CopyTokenToClipboard">@(_mcpCopied ? "Copie OK" : "Copier")</Button>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <Button Variant="primary" OnClick="DismissTokenModal">J'ai copié, fermer</Button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ── Section Pomodoro ──────────────────────────────────────── -->
        <Card class="kf-section">
            <h2 class="kf-section__title">🍅 Pomodoro</h2>
            <EditForm Model="_form" OnValidSubmit="SavePomodoroSettings">
                <DataAnnotationsValidator />
                <div class="kf-pomo-form">

                <div class="kf-grid3">
                    <div>
                        <label class="kf-field-label" for="sprintDuration">Sprint (min)</label>
                        <input id="sprintDuration"
                               type="number"
                               class="kf-input"
                               @bind="_form.SprintDuration"
                               min="1"
                               max="120" />
                    </div>
                    <div>
                        <label class="kf-field-label" for="shortBreakDuration">Pause courte</label>
                        <input id="shortBreakDuration"
                               type="number"
                               class="kf-input"
                               @bind="_form.ShortBreakDuration"
                               min="1"
                               max="120" />
                    </div>
                    <div>
                        <label class="kf-field-label" for="longBreakDuration">Pause longue</label>
                        <input id="longBreakDuration"
                               type="number"
                               class="kf-input"
                               @bind="_form.LongBreakDuration"
                               min="1"
                               max="120" />
                    </div>
                </div>

                <Alert Tone="info">
                    <strong>Rappel :</strong> Une pause longue est recommandée tous les 4 sprints. Entre 1 et 120 minutes.
                </Alert>

                @if (_successMessage is not null)
                {
                    <div style="margin-top: 0.75rem;">
                        <Alert Tone="success">@_successMessage</Alert>
                    </div>
                }

                @if (_errorMessage is not null)
                {
                    <div style="margin-top: 0.75rem;">
                        <Alert Tone="danger">@_errorMessage</Alert>
                    </div>
                }

                <div class="kf-actions">
                    <Button Type="submit"
                            Variant="primary"
                            Disabled="@_saving">
                        @(_saving ? "Enregistrement…" : "Enregistrer")
                    </Button>
                    <Button Variant="secondary"
                            Disabled="@_saving"
                            OnClick="ResetToDefaults">Réinitialiser</Button>
                </div>
                </div>
            </EditForm>
        </Card>

    </div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private string? _successMessage;
    private string? _errorMessage;
    private SettingsForm _form = new();
    private string _selectedTheme = "System";
    private string _selectedRingtone = "AlarmClock";

    // MCP Token state
    private bool _mcpLoading = true;
    private bool _mcpHasToken;
    private bool _mcpLoadError;
    private DateTime? _mcpExpiresAt;
    private bool _mcpActionInProgress;
    private string? _mcpRawToken;
    private bool _mcpCopied;
    private string? _mcpError;

    private sealed class SettingsForm
    {
        public int SprintDuration { get; set; } = 25;
        public int ShortBreakDuration { get; set; } = 5;
        public int LongBreakDuration { get; set; } = 15;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load Pomodoro settings
        var pomodoroSettings = await PomodoroApi.GetSettingsAsync();
        if (pomodoroSettings is not null)
        {
            _form.SprintDuration = pomodoroSettings.SprintDurationMinutes;
            _form.ShortBreakDuration = pomodoroSettings.ShortBreakDurationMinutes;
            _form.LongBreakDuration = pomodoroSettings.LongBreakDurationMinutes;
        }

        // Load theme preference
        var userSettings = await SettingsApi.GetSettingsAsync();
        if (userSettings is not null)
        {
            _selectedTheme = userSettings.ThemePreference;
            _selectedRingtone = userSettings.RingtonePreference;
            await ApplyTheme(_selectedTheme);
        }

        // Load MCP token status
        await LoadMcpStatusAsync();

        _loaded = true;
    }

    private async Task LoadMcpStatusAsync()
    {
        _mcpLoading = true;
        _mcpLoadError = false;
        var status = await McpTokenApi.GetStatusAsync();
        if (status is not null)
        {
            _mcpHasToken = status.HasToken;
            _mcpExpiresAt = status.ExpiresAt;
        }
        else
        {
            _mcpLoadError = true;
        }
        _mcpLoading = false;
    }

    private async Task GenerateToken()
    {
        _mcpActionInProgress = true;
        _mcpError = null;
        _mcpCopied = false;
        try
        {
            var rawToken = await McpTokenApi.GenerateAsync();
            if (rawToken is not null)
            {
                _mcpRawToken = rawToken;
                _mcpHasToken = true;
                _mcpExpiresAt = DateTime.UtcNow.AddYears(1);
            }
            else
            {
                _mcpError = "La génération du token a échoué. Veuillez réessayer.";
            }
        }
        finally
        {
            _mcpActionInProgress = false;
        }
    }

    private async Task RegenerateToken()
    {
        _mcpActionInProgress = true;
        _mcpError = null;
        _mcpCopied = false;
        try
        {
            // The server atomically replaces any existing token — no client-side revoke needed
            var rawToken = await McpTokenApi.GenerateAsync();
            if (rawToken is not null)
            {
                _mcpRawToken = rawToken;
                _mcpHasToken = true;
                _mcpExpiresAt = DateTime.UtcNow.AddYears(1);
            }
            else
            {
                _mcpError = "La régénération du token a échoué. Veuillez réessayer.";
                await LoadMcpStatusAsync();
            }
        }
        finally
        {
            _mcpActionInProgress = false;
        }
    }

    private async Task RevokeToken()
    {
        _mcpActionInProgress = true;
        _mcpError = null;
        try
        {
            var success = await McpTokenApi.RevokeAsync();
            if (success)
            {
                _mcpHasToken = false;
                _mcpExpiresAt = null;
            }
            else
            {
                _mcpError = "La révocation du token a échoué. Veuillez réessayer.";
            }
        }
        finally
        {
            _mcpActionInProgress = false;
        }
    }

    private async Task CopyTokenToClipboard()
    {
        if (_mcpRawToken is null) return;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _mcpRawToken);
        _mcpCopied = true;
    }

    private void DismissTokenModal()
    {
        _mcpRawToken = null;
        _mcpCopied = false;
    }

    private async Task OnThemeChanged()
    {
        await ApplyTheme(_selectedTheme);
        await SettingsApi.SaveThemePreferenceAsync(_selectedTheme);
    }

    private async Task OnRingtoneChanged()
    {
        await SettingsApi.SaveRingtonePreferenceAsync(_selectedRingtone);
    }

    private async Task PreviewRingtone()
    {
        await SoundService.PlayRingtoneAsync(_selectedRingtone);
    }

    private async Task ApplyTheme(string theme)
    {
        var effectiveTheme = theme;

        if (theme == "System")
        {
            var isDark = await JSRuntime.InvokeAsync<bool>("eval", "window.matchMedia('(prefers-color-scheme: dark)').matches");
            effectiveTheme = isDark ? "Dark" : "Light";
        }

        await JSRuntime.InvokeVoidAsync("eval",
            effectiveTheme == "Dark"
                ? "document.documentElement.setAttribute('data-bs-theme', 'dark')"
                : "document.documentElement.setAttribute('data-bs-theme', 'light')");
    }

    private async Task SavePomodoroSettings()
    {
        _saving = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            if (_form.SprintDuration < 1 || _form.SprintDuration > 120)
            {
                _errorMessage = "La durée du sprint doit être entre 1 et 120 minutes.";
                return;
            }

            if (_form.ShortBreakDuration < 1 || _form.ShortBreakDuration > 120)
            {
                _errorMessage = "La durée de la pause courte doit être entre 1 et 120 minutes.";
                return;
            }

            if (_form.LongBreakDuration < 1 || _form.LongBreakDuration > 120)
            {
                _errorMessage = "La durée de la pause longue doit être entre 1 et 120 minutes.";
                return;
            }

            var success = await PomodoroApi.SaveSettingsAsync(
                _form.SprintDuration,
                _form.ShortBreakDuration,
                _form.LongBreakDuration);

            if (success)
            {
                _successMessage = "Paramètres enregistrés avec succès !";
            }
            else
            {
                _errorMessage = "Impossible d'enregistrer les paramètres. Vérifiez les valeurs saisies.";
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void ResetToDefaults()
    {
        _form.SprintDuration = 25;
        _form.ShortBreakDuration = 5;
        _form.LongBreakDuration = 15;
        _successMessage = null;
        _errorMessage = null;
    }
}
