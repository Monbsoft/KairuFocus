@page "/pomodoro"
@attribute [Authorize]
@using KairuFocus.Web.Services
@using KairuFocus.Web.Components.Design
@inject PomodoroApiClient PomodoroApi
@inject TaskApiClient TaskApi
@inject SettingsApiClient SettingsApi
@inject ISoundService SoundService
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="kf-pomo">

    <!-- En-tête -->
    <div class="kf-pomo__head">
        <h1>Pomodoro</h1>
        <Button Variant="ghost" OnClick="NavigateToSprintLibre">Sprint libre</Button>
    </div>

    @if (!_loaded)
    {
        <p class="text-muted">Chargement…</p>
    }
    else
    {
        <!-- Onglets de type de session (masqués pendant une session active) -->
        @if (_session is null || _session.Status is "Completed" or "Interrupted")
        {
            <div class="kf-tabs" role="tablist" aria-label="Type de session">
                <button role="tab"
                        aria-selected="@(_selectedSessionType == "Sprint" ? "true" : "false")"
                        class="kf-tab @(_selectedSessionType == "Sprint" ? "is-active" : "")"
                        @onclick='() => SelectSessionType("Sprint")'>
                    🍅 Sprint (@_sprintDuration min)
                </button>
                <button role="tab"
                        aria-selected="@(_selectedSessionType == "ShortBreak" ? "true" : "false")"
                        class="kf-tab @(_selectedSessionType == "ShortBreak" ? "is-active" : "")"
                        @onclick='() => SelectSessionType("ShortBreak")'>
                    ☕ Pause courte (@_shortBreakDuration min)
                </button>
                <button role="tab"
                        aria-selected="@(_selectedSessionType == "LongBreak" ? "true" : "false")"
                        class="kf-tab @(_selectedSessionType == "LongBreak" ? "is-active" : "")"
                        @onclick='() => SelectSessionType("LongBreak")'>
                    🌙 Pause longue (@_longBreakDuration min)
                </button>
            </div>
        }

        <!-- Anneau de progression -->
        <div class="kf-pomo__ring">
            <ProgressRing Progress="@Progress"
                          State="@RingState"
                          Size="236"
                          Label="@TimeDisplay"
                          Sublabel="@StatusLabel" />
        </div>

        <!-- Boutons de contrôle -->
        <div class="kf-pomo__controls">
            @if (_session is null || _session.Status is "Completed" or "Interrupted")
            {
                <Button Variant="primary" Size="lg" OnClick="StartSession">▶ Démarrer</Button>
            }
            else if (_session.Status == "Active")
            {
                <Button Variant="secondary" Size="lg" OnClick="InterruptSession">⏹ Interrompre</Button>
            }
        </div>

        <!-- Résultat fin de session (Peak-End) -->
        @if (_completedSessionType is not null)
        {
            var (icon, label, next) = _completedSessionType switch
            {
                "Sprint"     => ("🍅", "Sprint terminé !", _suggestedNextSessionType switch { "LongBreak" => "Pause recommandée : longue", "ShortBreak" => "Pause recommandée : courte", _ => "" }),
                "ShortBreak" => ("☕", "Pause courte terminée !", "Sprint recommandé !"),
                "LongBreak"  => ("🌙", "Pause longue terminée !", "Sprint recommandé !"),
                _            => ("✅", "Session terminée !", "")
            };
            <Alert Tone="success">@icon @label <strong>@next</strong></Alert>
        }

        <!-- Tâches liées au sprint actif — masquées pendant une pause -->
        @if (_session?.Status == "Active" && _session.SessionType == "Sprint")
        {
            <div class="kf-sprinttasks">
                <h2>Tâches du sprint</h2>

                @if (_linkedTasks.Count > 0)
                {
                    <div class="kf-linked">
                        @foreach (var task in _linkedTasks)
                        {
                            var currentTask = task;
                            <div class="kf-linkedrow">
                                <span class="kf-linkedrow__title @(currentTask.Status == "Done" ? "kf-linkedrow__title--done" : "")">
                                    @currentTask.Title
                                </span>
                                <span class="kf-linkedrow__actions">
                                    <Badge Status="@currentTask.Status" />
                                    @if (currentTask.Status == "Todo")
                                    {
                                        <IconButton Label="@($"Marquer {currentTask.Title} en cours")"
                                                    Tone="primary"
                                                    Outline="true"
                                                    Size="sm"
                                                    OnClick="() => SetTaskInProgress(currentTask.Id)">
                                            ▶
                                        </IconButton>
                                    }
                                    @if (currentTask.Status != "Done")
                                    {
                                        <IconButton Label="@($"Terminer {currentTask.Title}")"
                                                    Tone="success"
                                                    Outline="true"
                                                    Size="sm"
                                                    OnClick="() => CompleteLinkedTask(currentTask.Id)">
                                            ✓
                                        </IconButton>
                                    }
                                    <IconButton Label="@($"Retirer {currentTask.Title} du sprint")"
                                                Tone="danger"
                                                Outline="true"
                                                Size="sm"
                                                OnClick="() => UnlinkTask(currentTask.Id)">
                                        ✕
                                    </IconButton>
                                </span>
                            </div>
                        }
                    </div>
                }

                <!-- Lier une tâche existante -->
                <div class="kf-pomo__link-row">
                    <select class="kf-select kf-select--sm" @bind="_selectedTaskIdToLink">
                        <option value="">— Lier une tâche existante —</option>
                        @foreach (var task in GetLinkableTasks())
                        {
                            <option value="@task.Id">@FormatTaskOption(task)</option>
                        }
                    </select>
                    <Button Variant="secondary"
                            Size="sm"
                            Disabled="@string.IsNullOrEmpty(_selectedTaskIdToLink)"
                            OnClick="LinkExistingTask">
                        Lier
                    </Button>
                </div>

                <!-- Créer une nouvelle tâche pendant le sprint -->
                <div class="kf-pomo__newtask-row">
                    <input class="kf-input kf-input--sm"
                           placeholder="Nouvelle tâche pendant le sprint…"
                           @bind="_newTaskTitle"
                           @bind:event="oninput"
                           @onkeydown="OnNewTaskKeyDown" />
                    <Button Variant="primary"
                            Size="sm"
                            Disabled="@string.IsNullOrWhiteSpace(_newTaskTitle)"
                            OnClick="CreateTask">
                        +
                    </Button>
                </div>
            </div>
        }

        <!-- Erreur -->
        @if (_errorMessage is not null)
        {
            <Alert Tone="danger">@_errorMessage</Alert>
        }
    }

</div>

@code {
    // ── Constantes SVG (conservées pour DashOffset / Progress) ────────────
    private const double Radius = 95.0;
    private readonly double _circumference = 2 * Math.PI * Radius;

    // ── État ──────────────────────────────────────────────────────────────
    private bool _loaded;
    private PomodoroSessionDto? _session;
    private string? _completedSessionType;
    private string? _suggestedNextSessionType;
    private List<TaskDto> _allTasks = [];
    private List<TaskDto> _linkedTasks = [];
    private string? _errorMessage;
    private string _newTaskTitle = string.Empty;
    private string _selectedTaskIdToLink = string.Empty;

    // ── Session type selection ────────────────────────────────────────────
    private string _selectedSessionType = "Sprint";
    private int _sprintDuration = 25;
    private int _shortBreakDuration = 5;
    private int _longBreakDuration = 15;
    private string _ringtonePreference = "AlarmClock";

    // ── Timer ─────────────────────────────────────────────────────────────
    private int _remainingSeconds;
    private int _totalSeconds;
    private CancellationTokenSource? _timerCts;

    // ── Computed — présentation ───────────────────────────────────────────

    /// <summary>Fraction restante pour ProgressRing (1.0 = plein, 0.0 = vide).</summary>
    private double Progress =>
        (_totalSeconds > 0 && _session?.Status == "Active")
            ? Math.Clamp((double)_remainingSeconds / _totalSeconds, 0.0, 1.0)
            : (_session?.Status == "Completed" ? 1.0 : 1.0);

    /// <summary>
    /// Mapping Status + SessionType → state ProgressRing.
    /// Valeurs réelles C# : Status = "Active"/"Completed"/"Interrupted"/null
    ///                       SessionType = "Sprint"/"ShortBreak"/"LongBreak"
    /// </summary>
    private string RingState => _session?.Status switch
    {
        "Active" => _session.SessionType switch
        {
            "Sprint"     => "sprint",
            "ShortBreak" => "shortBreak",
            "LongBreak"  => "longBreak",
            _            => "sprint"
        },
        "Completed"   => "done",
        "Interrupted" => "interrupted",
        _             => "idle"
    };

    private string TimeDisplay =>
        _remainingSeconds >= 0
            ? $"{_remainingSeconds / 60:D2}:{_remainingSeconds % 60:D2}"
            : "00:00";

    private string StatusLabel => _session?.Status switch
    {
        "Active" => _session.SessionType switch
        {
            "Sprint"     => "Sprint en cours",
            "ShortBreak" => "Pause courte",
            "LongBreak"  => "Pause longue",
            _            => "En cours"
        },
        "Completed"   => "Terminé",
        "Interrupted" => "Interrompu",
        _             => "Prêt"
    };

    // DashOffset conservé pour compatibilité (non utilisé directement dans le template — Progress le remplace)
    private double DashOffset
    {
        get
        {
            if (_totalSeconds <= 0 || _session?.Status != "Active")
                return 0;
            var progress = Math.Clamp((double)_remainingSeconds / _totalSeconds, 0, 1);
            return _circumference * (1 - progress);
        }
    }

    private IEnumerable<TaskDto> GetLinkableTasks() =>
        _allTasks.Where(t =>
            t.Status != "Done" &&
            (_session is null || !_session.LinkedTaskIds.Contains(t.Id)));

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _allTasks = await TaskApi.GetAllAsync();
        _session  = await PomodoroApi.GetCurrentSessionAsync();

        var suggested = await PomodoroApi.GetSuggestedSessionTypeAsync();
        if (suggested is not null)
        {
            _selectedSessionType = suggested.SuggestedType;
            _sprintDuration = suggested.SprintDurationMinutes;
            _shortBreakDuration = suggested.ShortBreakDurationMinutes;
            _longBreakDuration = suggested.LongBreakDurationMinutes;
        }

        var userSettings = await SettingsApi.GetSettingsAsync();
        if (userSettings is not null)
        {
            _ringtonePreference = userSettings.RingtonePreference;
        }

        if (_session?.Status == "Active")
        {
            InitTimer(_session);
            await StartTimerLoop();
        }

        RefreshLinkedTasks();
        _loaded = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (_timerCts is not null)
        {
            await _timerCts.CancelAsync();
            _timerCts.Dispose();
        }
    }

    // ── Actions ───────────────────────────────────────────────────────────
    private void SelectSessionType(string sessionType)
    {
        _selectedSessionType = sessionType;
        StateHasChanged();
    }

    private void NavigateToSprintLibre() => Nav.NavigateTo("/pomodoro/libre");

    private async Task StartSession()
    {
        _errorMessage = null;
        _completedSessionType = null;
        _suggestedNextSessionType = null;

        var started = await PomodoroApi.StartSessionAsync(_selectedSessionType);
        if (started is null)
        {
            _errorMessage = "Impossible de démarrer la session.";
            return;
        }

        _session = started;
        InitTimer(_session);
        RefreshLinkedTasks();
        await StartTimerLoop();
    }

    private async Task InterruptSession()
    {
        _errorMessage = null;
        await StopTimer();

        var ok = await PomodoroApi.InterruptSessionAsync();
        if (!ok)
        {
            _errorMessage = "Impossible d'interrompre le sprint.";
            return;
        }

        _session = await PomodoroApi.GetCurrentSessionAsync();
        _completedSessionType = null;
        RefreshLinkedTasks();
    }

    private async Task OnTimerCompleted()
    {
        await SoundService.PlayRingtoneAsync(_ringtonePreference);

        var completedType = _session?.SessionType;
        var success = await PomodoroApi.CompleteSessionAsync();
        if (!success)
        {
            _errorMessage = "Impossible de terminer la session.";
            StateHasChanged();
            return;
        }

        _completedSessionType = completedType;
        _session = await PomodoroApi.GetCurrentSessionAsync();
        _remainingSeconds = 0;

        var suggested = await PomodoroApi.GetSuggestedSessionTypeAsync();
        _suggestedNextSessionType = suggested?.SuggestedType;
        if (suggested is not null)
            _selectedSessionType = suggested.SuggestedType;

        RefreshLinkedTasks();
        StateHasChanged();
    }

    private async Task LinkExistingTask()
    {
        if (!Guid.TryParse(_selectedTaskIdToLink, out var id)) return;
        _errorMessage = null;

        var ok = await PomodoroApi.LinkTaskAsync(id);
        if (!ok) { _errorMessage = "Impossible de lier la tâche."; return; }

        _session = await PomodoroApi.GetCurrentSessionAsync();
        _selectedTaskIdToLink = string.Empty;
        RefreshLinkedTasks();
    }

    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(_newTaskTitle)) return;
        _errorMessage = null;

        var created = await PomodoroApi.CreateTaskDuringSessionAsync(_newTaskTitle.Trim());
        if (created is null) { _errorMessage = "Impossible de créer la tâche."; return; }

        _allTasks.Add(created);
        _session = await PomodoroApi.GetCurrentSessionAsync();
        _newTaskTitle = string.Empty;
        RefreshLinkedTasks();
    }

    private async Task SetTaskInProgress(Guid taskId)
    {
        _errorMessage = null;
        var updated = await PomodoroApi.UpdateTaskStatusAsync(taskId, "InProgress");
        if (updated is null) { _errorMessage = "Impossible de mettre à jour le statut."; return; }
        UpdateLocalTask(updated);
    }

    private async Task UnlinkTask(Guid taskId)
    {
        _errorMessage = null;
        var ok = await PomodoroApi.UnlinkTaskAsync(taskId);
        if (!ok) { _errorMessage = "Impossible de retirer la tâche du sprint."; return; }

        _session = await PomodoroApi.GetCurrentSessionAsync();
        RefreshLinkedTasks();
    }

    private async Task CompleteLinkedTask(Guid taskId)
    {
        _errorMessage = null;
        var updated = await PomodoroApi.UpdateTaskStatusAsync(taskId, "Done");
        if (updated is null) { _errorMessage = "Impossible de compléter la tâche."; return; }
        UpdateLocalTask(updated);
    }

    private async Task OnNewTaskKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newTaskTitle))
            await CreateTask();
    }

    // ── Timer internals ───────────────────────────────────────────────────
    private void InitTimer(PomodoroSessionDto session)
    {
        _totalSeconds = session.PlannedDurationMinutes * 60;

        if (session.StartedAt.HasValue)
        {
            var elapsed = (int)(DateTime.UtcNow - session.StartedAt.Value).TotalSeconds;
            _remainingSeconds = Math.Max(0, _totalSeconds - elapsed);
        }
        else
        {
            _remainingSeconds = _totalSeconds;
        }
    }

    private async Task StartTimerLoop()
    {
        await StopTimer();
        _timerCts = new CancellationTokenSource();
        var token = _timerCts.Token;

        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            try
            {
                while (await timer.WaitForNextTickAsync(token))
                {
                    _remainingSeconds = Math.Max(0, _remainingSeconds - 1);
                    await InvokeAsync(StateHasChanged);

                    if (_remainingSeconds <= 0)
                    {
                        await InvokeAsync(OnTimerCompleted);
                        break;
                    }
                }
            }
            catch (OperationCanceledException) { }
            catch (Exception ex)
            {
                await InvokeAsync(() =>
                {
                    _errorMessage = $"Erreur de fin de session : {ex.Message}";
                    StateHasChanged();
                });
            }
        }, token);
    }

    private async Task StopTimer()
    {
        if (_timerCts is not null)
        {
            await _timerCts.CancelAsync();
            _timerCts.Dispose();
            _timerCts = null;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────
    private void RefreshLinkedTasks()
    {
        if (_session is null) { _linkedTasks = []; return; }
        var ids = _session.LinkedTaskIds.ToHashSet();
        _linkedTasks = _allTasks.Where(t => ids.Contains(t.Id)).ToList();
    }

    private void UpdateLocalTask(TaskDto updated)
    {
        var idx = _allTasks.FindIndex(t => t.Id == updated.Id);
        if (idx >= 0) _allTasks[idx] = updated;
        RefreshLinkedTasks();
    }

    private static string FormatTaskOption(TaskDto task) =>
        task.Tags is { Count: > 0 }
            ? $"[{task.Tags[0]}] {task.Title}"
            : task.Title;
}
