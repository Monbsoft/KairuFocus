@page "/tasks/{Id:guid}/edit"
@attribute [Authorize]
@using KairuFocus.Web.Services
@inject TaskApiClient Api
@inject NavigationManager Nav
@inject MarkdownService MarkdownSvc

<PageTitle>Modifier — KairuFocus</PageTitle>

<div class="kf-te">
    @if (notFound)
    {
        <Alert Tone="warning">Tâche introuvable.</Alert>
        <div class="kf-te__actions">
            <Button Variant="secondary" OnClick="GoBack">Retour</Button>
        </div>
    }
    else if (task is null)
    {
        <p style="color: var(--text-muted);">Chargement…</p>
    }
    else
    {
        <div class="kf-te__back">
            <Button Variant="ghost" Size="sm" OnClick="GoBack">← Retour</Button>
        </div>

        <h1 class="kf-te__title" style="margin-bottom: 1.25rem;">Modifier la tâche</h1>

        @if (errorMessage is not null)
        {
            <Alert Tone="danger">@errorMessage</Alert>
        }

        @* Champ Titre *@
        <div class="kf-te__field">
            <label class="kf-te__label" for="edit-title">Titre</label>
            <input id="edit-title"
                   class="kf-input"
                   placeholder="Titre…"
                   @bind="editTitle"
                   @bind:event="oninput" />
        </div>

        @* Champ Tags *@
        <div class="kf-te__field">
            <span class="kf-te__label">Tags</span>
            <div class="kf-te__tags">
                @foreach (var tag in editTags)
                {
                    var capturedTag = tag;
                    <Tag Hash ChildContent="@capturedTag" OnRemove="() => RemoveEditTag(capturedTag)" />
                }
            </div>
            <div style="max-width: 320px;">
                <input class="kf-input"
                       placeholder="@(editTags.Count >= MaxTags ? "Maximum 5 tags" : "Ajouter un tag… (Entrée)")"
                       aria-label="Ajouter un tag"
                       disabled="@(editTags.Count >= MaxTags)"
                       @bind="editTagInput"
                       @bind:event="oninput"
                       @onkeydown="OnEditTagKeyDown" />
            </div>
        </div>

        @* Champ Description — onglets Éditer / Prévisualiser *@
        <div class="kf-te__field">
            <span class="kf-te__label">Description</span>

            <div class="kf-tabs2" role="tablist">
                <button role="tab"
                        aria-selected="@(editTab == "edit")"
                        class="kf-tab2 @(editTab == "edit" ? "is-active" : "")"
                        @onclick='() => editTab = "edit"'>
                    Éditer
                </button>
                <button role="tab"
                        aria-selected="@(editTab == "preview")"
                        class="kf-tab2 @(editTab == "preview" ? "is-active" : "")"
                        @onclick='() => editTab = "preview"'>
                    Prévisualiser
                </button>
            </div>

            @if (editTab == "edit")
            {
                <textarea class="kf-md kf-md-edit"
                          rows="10"
                          aria-label="Description Markdown"
                          placeholder="Description en Markdown…"
                          @bind="editDescMd"
                          @bind:event="oninput"></textarea>
                <div class="kf-charcount @(editDescMd.Length > DescriptionMaxLength ? "kf-charcount--over" : "")">
                    @editDescMd.Length / @DescriptionMaxLength
                </div>
            }
            else
            {
                <div class="kf-md kf-mdpreview">
                    @if (string.IsNullOrWhiteSpace(editDescMd))
                    {
                        <p class="kf-md__empty">Aucun contenu à prévisualiser.</p>
                    }
                    else
                    {
                        @((MarkupString)MarkdownSvc.Render(editDescMd))
                    }
                </div>
            }
        </div>

        <div class="kf-te__actions">
            <Button Variant="primary"
                    Disabled="@(editDescMd.Length > DescriptionMaxLength || string.IsNullOrWhiteSpace(editTitle))"
                    OnClick="SaveEdit">
                Enregistrer
            </Button>
            <Button Variant="secondary" OnClick="GoBack">Annuler</Button>
        </div>
    }
</div>

@code {
    private const int MaxTags = 5;
    private const int DescriptionMaxLength = 5000;

    [Parameter] public Guid Id { get; set; }

    private TaskDto? task;
    private bool notFound;
    private string? errorMessage;

    private string editTitle = string.Empty;
    private string editDescMd = string.Empty;
    private string editTab = "edit";
    private string editTagInput = string.Empty;
    private List<string> editTags = [];

    protected override async Task OnInitializedAsync()
    {
        task = await Api.GetByIdAsync(Id);
        notFound = task is null;
        if (task is not null && task.Status == "Done")
        {
            Nav.NavigateTo($"/tasks/{Id}");
            return;
        }
        if (task is not null)
        {
            editTitle = task.Title;
            editDescMd = task.Description ?? string.Empty;
            editTags = task.Tags is not null ? [.. task.Tags] : [];
        }
    }

    private void AddEditTagFromInput()
    {
        var trimmed = editTagInput.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || editTags.Count >= MaxTags) return;
        if (editTags.Any(t => string.Equals(t, trimmed, StringComparison.OrdinalIgnoreCase))) return;
        if (trimmed.Length > 30) return;
        editTags.Add(trimmed);
        editTagInput = string.Empty;
    }

    private void RemoveEditTag(string tag) => editTags.Remove(tag);

    private void OnEditTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddEditTagFromInput();
    }

    private async Task SaveEdit()
    {
        if (task is null || editDescMd.Length > DescriptionMaxLength) return;
        errorMessage = null;
        var description = string.IsNullOrWhiteSpace(editDescMd) ? null : editDescMd.Trim();
        var updated = await Api.UpdateAsync(Id, editTitle.Trim(), description, editTags.Count > 0 ? editTags : []);
        if (updated is not null)
        {
            Nav.NavigateTo("/tasks");
        }
        else
        {
            errorMessage = "Erreur lors de la modification.";
        }
    }

    private void GoBack() => Nav.NavigateTo("/tasks");
}
