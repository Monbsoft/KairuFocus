@page "/login"
@attribute [AllowAnonymous]
@using KairuFocus.Web.Auth
@inject NavigationManager Nav
@inject AuthService AuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject IStringLocalizer<Login> Loc

<PageTitle>@Loc["PageTitle"]</PageTitle>

<div class="kf-login">
    <div class="kf-login__card">
        <div class="kf-login__logo" aria-hidden="true">K</div>
        <h1 class="kf-login__title">@Loc["Title"]</h1>
        <p class="kf-login__sub">@Loc["Subtitle"]</p>

        @if (_error is not null)
        {
            <Alert Tone="danger">@_error</Alert>
        }

        <Button Variant="accent" As="a" Href="@_githubLoginUrl">
            <Icon>@GithubIcon</Icon>
            <ChildContent>@Loc["LoginButton"]</ChildContent>
        </Button>
    </div>
</div>

@code {
    private string? _error;
    private string _githubLoginUrl = "/api/auth/github";

    // GitHub SVG icon — brand asset, rendered via MarkupString to avoid Razor SVG parsing issues.
    private static readonly RenderFragment GithubIcon = builder =>
    {
        builder.AddMarkupContent(0,
            "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">" +
            "<path d=\"M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z\"/>" +
            "</svg>");
    };

    protected override void OnInitialized()
    {
        var apiBase = Configuration["ApiBaseUrl"] ?? string.Empty;
        _githubLoginUrl = $"{apiBase}/api/auth/github";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Read token from URL fragment (e.g. /#token=xxx)
        var uri = new Uri(Nav.Uri);
        var fragment = uri.Fragment;

        if (fragment.StartsWith("#token=", StringComparison.OrdinalIgnoreCase))
        {
            var token = Uri.UnescapeDataString(fragment[7..]);
            await AuthService.SetTokenAsync(token);
            AuthStateProvider.NotifyAuthenticationStateChanged();
            Nav.NavigateTo("/dashboard", replace: true);
            return;
        }

        if (fragment.StartsWith("#auth-error=", StringComparison.OrdinalIgnoreCase))
        {
            _error = fragment[12..] switch
            {
                "denied" => Loc["Error.Denied"],
                "no-id"  => Loc["Error.NoId"],
                _        => Loc["Error.Generic"]
            };
            StateHasChanged();
            return;
        }

        // Already authenticated — redirect
        if (await AuthService.IsAuthenticatedAsync())
            Nav.NavigateTo("/dashboard", replace: true);
    }
}
