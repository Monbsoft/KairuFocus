@page "/tasks"
@attribute [Authorize]
@implements IDisposable
@using KairuFocus.Web.Services
@inject TaskApiClient Api
@inject NavigationManager Nav
@inject MarkdownService MarkdownSvc

<PageTitle>Tâches — KairuFocus</PageTitle>

<div class="kf-tasks">
    <h1 class="kf-tasks__title">Tâches</h1>

    @* Zone d'ajout — Card DS *@
    <Card Class="kf-addcard">
        <div class="kf-addcard__row">
            <input class="kf-input"
                   placeholder="Titre de la tâche…"
                   aria-label="Titre de la tâche"
                   @bind="newTitle"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown" />
            <textarea class="kf-input kf-input--textarea"
                      placeholder="Description (optionnelle)…"
                      aria-label="Description"
                      @bind="newDescription"
                      @bind:event="oninput"
                      rows="2"></textarea>

            <div class="kf-addtags">
                @foreach (var tag in newTags)
                {
                    var capturedTag = tag;
                    <Tag Hash ChildContent="@capturedTag" OnRemove="() => RemoveNewTag(capturedTag)" />
                }
                <div style="max-width: 220px; flex: 1 1 auto;">
                    <input class="kf-input"
                           placeholder="@(newTags.Count >= MaxTags ? "Maximum 5 tags" : "Ajouter un tag… (Entrée)")"
                           aria-label="Ajouter un tag"
                           disabled="@(newTags.Count >= MaxTags)"
                           @bind="newTagInput"
                           @bind:event="oninput"
                           @onkeydown="OnNewTagKeyDown" />
                </div>
            </div>

            <div>
                <Button Variant="primary" Disabled="@string.IsNullOrWhiteSpace(newTitle)" OnClick="AddTask">Ajouter</Button>
            </div>
        </div>
    </Card>

    @* Filtres *@
    <div class="kf-filters">
        <div class="kf-filters__search">
            <input class="kf-input"
                   placeholder="Rechercher par titre…"
                   aria-label="Rechercher"
                   value="@searchTerm"
                   @oninput="OnSearchInput" />
        </div>
        <div style="width: 180px;">
            <select class="kf-select"
                    aria-label="Filtre de statut"
                    value="@statusFilter"
                    @onchange="OnStatusChanged">
                <option value="OpenOnly">Ouvertes</option>
                <option value="All">Toutes</option>
                <option value="Pending">En attente</option>
                <option value="InProgress">En cours</option>
                <option value="Done">Terminées</option>
            </select>
        </div>
    </div>

    @* Erreur *@
    @if (errorMessage is not null)
    {
        <Alert Tone="danger">@errorMessage</Alert>
    }

    @* Chargement *@
    @if (tasks is null)
    {
        <p style="color: var(--text-muted);">Chargement…</p>
    }
    else if (tasks.Count == 0)
    {
        <div class="kf-empty" role="status">
            <div class="kf-empty__icon" aria-hidden="true">📋</div>
            <div class="kf-empty__title">Aucune tâche ne correspond aux filtres.</div>
            <div>Ajoutez votre première tâche ci-dessus pour commencer.</div>
        </div>
    }
    else
    {
        <div class="kf-tasklist">
            @foreach (var task in tasks)
            {
                @* Capture locale — évite le piège de closure sur variable de boucle *@
                var current = task;
                <div class="kf-taskrow">
                    @* Checkbox complétion — cible ≥44px via padding/margin compensatoire *@
                    <div class="kf-taskrow__check">
                        <input type="checkbox"
                               class="kf-taskrow__checkbox"
                               checked="@(current.Status == "Done")"
                               disabled="@(current.Status == "Done")"
                               aria-label="@($"Compléter {current.Title}")"
                               @onchange="() => CompleteTask(current.Id)" />
                    </div>

                    @* Corps de la rangée *@
                    <div class="kf-taskrow__body">
                        <button class="kf-taskrow__title @(current.Status == "Done" ? "kf-taskrow__title--done" : "")"
                                @onclick="() => NavigateToDetail(current.Id)">
                            @current.Title
                        </button>

                        @if (!string.IsNullOrWhiteSpace(current.Description))
                        {
                            <div class="kf-taskrow__desc">@((MarkupString)MarkdownSvc.Render(current.Description))</div>
                        }

                        <div class="kf-taskrow__meta">
                            <Badge Status="@current.Status" />
                            @if (current.Tags is { Count: > 0 })
                            {
                                @foreach (var tag in current.Tags)
                                {
                                    <Tag Hash ChildContent="@tag" />
                                }
                            }
                        </div>
                    </div>

                    @* Actions *@
                    <div class="kf-taskrow__actions">
                        @if (current.Status != "Done")
                        {
                            <IconButton Label="@($"Modifier {current.Title}")"
                                        Tone="primary"
                                        Outline="true"
                                        OnClick="() => NavigateToEdit(current.Id)">
                                ✎
                            </IconButton>
                        }
                        <IconButton Label="@($"Supprimer {current.Title}")"
                                    Tone="danger"
                                    Outline="true"
                                    OnClick="() => DeleteTask(current.Id)">
                            ✕
                        </IconButton>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private const int MaxTags = 5;

    private List<TaskDto>? tasks;
    private string newTitle = string.Empty;
    private string newDescription = string.Empty;
    private string newTagInput = string.Empty;
    private List<string> newTags = [];
    private string? errorMessage;
    private string searchTerm = string.Empty;
    private string statusFilter = "OpenOnly";
    private CancellationTokenSource? _debounceToken;

    protected override async Task OnInitializedAsync() => await LoadTasksAsync();

    private async Task LoadTasksAsync()
    {
        var search = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim();
        tasks = await Api.GetAllAsync(search, statusFilter);
    }

    private void NavigateToDetail(Guid id) => Nav.NavigateTo($"/tasks/{id}");

    private void NavigateToEdit(Guid id) => Nav.NavigateTo($"/tasks/{id}/edit");

    private async Task AddTask()
    {
        errorMessage = null;
        var description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim();
        var added = await Api.AddAsync(newTitle.Trim(), description, newTags.Count > 0 ? newTags : null);
        if (added is not null)
        {
            newTitle = string.Empty;
            newDescription = string.Empty;
            newTags = [];
            newTagInput = string.Empty;
            await LoadTasksAsync();
        }
        else
        {
            errorMessage = "Erreur lors de l'ajout de la tâche.";
        }
    }

    private void AddNewTagFromInput()
    {
        var trimmed = newTagInput.Trim();
        if (string.IsNullOrWhiteSpace(trimmed) || newTags.Count >= MaxTags) return;
        if (newTags.Any(t => string.Equals(t, trimmed, StringComparison.OrdinalIgnoreCase))) return;
        if (trimmed.Length > 30) return;
        newTags.Add(trimmed);
        newTagInput = string.Empty;
    }

    private void RemoveNewTag(string tag) => newTags.Remove(tag);

    private void OnNewTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddNewTagFromInput();
    }

    private async Task CompleteTask(Guid id)
    {
        errorMessage = null;
        if (await Api.CompleteAsync(id))
            await LoadTasksAsync();
        else
            errorMessage = "Erreur lors de la complétion.";
    }

    private async Task DeleteTask(Guid id)
    {
        errorMessage = null;
        if (await Api.DeleteAsync(id))
            await LoadTasksAsync();
        else
            errorMessage = "Erreur lors de la suppression.";
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, _debounceToken.Token);
            await LoadTasksAsync();
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        statusFilter = e.Value?.ToString() ?? "OpenOnly";
        await LoadTasksAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newTitle))
            await AddTask();
    }

    public void Dispose() => _debounceToken?.Dispose();
}
