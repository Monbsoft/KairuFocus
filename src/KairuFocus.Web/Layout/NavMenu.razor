@using KairuFocus.Web.Auth
@inject AuthService AuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@implements IDisposable

<div class="kf-side__brand-row">
    <span class="kf-side__brand" aria-hidden="true">K</span>
    <button title="Navigation menu" class="kf-side__toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass kf-nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="kf-nav" aria-label="Navigation principale">

        <div class="kf-navitem">
            <NavLink class="kf-navicon"
                     href="dashboard"
                     aria-label="Tableau de bord"
                     aria-current="@(IsActive("dashboard") ? "page" : null)"
                     Match="NavLinkMatch.Prefix">
                @* Home icon — house with chimney *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                <span class="kf-navicon__tip">Tableau de bord</span>
            </NavLink>
        </div>

        <div class="kf-navitem">
            <NavLink class="kf-navicon"
                     href="tasks"
                     aria-label="Taches"
                     aria-current="@(IsActive("tasks") ? "page" : null)"
                     Match="NavLinkMatch.Prefix">
                @* CheckSquare icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <polyline points="9 11 12 14 22 4" />
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                </svg>
                <span class="kf-navicon__tip">Taches</span>
            </NavLink>
        </div>

        <div class="kf-navitem">
            <NavLink class="kf-navicon"
                     href="pomodoro"
                     aria-label="Pomodoro"
                     aria-current="@(IsActive("pomodoro") ? "page" : null)"
                     Match="NavLinkMatch.Prefix">
                @* Tomato / timer icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <circle cx="12" cy="13" r="8" />
                    <path d="M12 5V3" />
                    <path d="M12 5c0 0 2-2 4-1" />
                    <line x1="12" y1="9" x2="12" y2="13" />
                    <line x1="14.5" y1="11" x2="12" y2="13" />
                </svg>
                <span class="kf-navicon__tip">Pomodoro</span>
            </NavLink>
        </div>

        <div class="kf-navitem">
            <NavLink class="kf-navicon"
                     href="journal"
                     aria-label="Journal"
                     aria-current="@(IsActive("journal") ? "page" : null)"
                     Match="NavLinkMatch.Prefix">
                @* Book / open book icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
                <span class="kf-navicon__tip">Journal</span>
            </NavLink>
        </div>

        <div class="kf-navitem kf-navitem--settings">
            <NavLink class="kf-navicon"
                     href="settings"
                     aria-label="Parametres"
                     aria-current="@(IsActive("settings") ? "page" : null)"
                     Match="NavLinkMatch.Prefix">
                @* Settings / gear icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                </svg>
                <span class="kf-navicon__tip">Parametres</span>
            </NavLink>
        </div>

        <div class="kf-navitem kf-navitem--logout">
            <button class="kf-navicon kf-navicon--btn"
                    aria-label="Deconnexion"
                    title="Deconnexion"
                    @onclick="LogoutAsync">
                @* Logout / log-out icon *@
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                <span class="kf-navicon__tip">Deconnexion</span>
            </button>
        </div>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    // ── aria-current="page" — WCAG 4.1.2 ────────────────────────────────
    // Blazor NavLink adds only the CSS class .active; it does NOT emit
    // aria-current. We subscribe to LocationChanged and recompute IsActive
    // on each navigation so that aria-current="page" is actually rendered
    // in the DOM (verified via browser DevTools / axe audit).
    private string _currentPath = "/";

    protected override void OnInitialized()
    {
        _currentPath = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentPath = new Uri(e.Location).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Returns true when the current URL path starts with /{segment}.
    /// Mirrors NavLinkMatch.Prefix behaviour used on the NavLink elements.
    /// </summary>
    private bool IsActive(string segment)
        => _currentPath.StartsWith("/" + segment, StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task LogoutAsync()
    {
        await AuthService.RemoveTokenAsync();
        AuthStateProvider.NotifyAuthenticationStateChanged();
        Nav.NavigateTo("/", forceLoad: false);
    }
}
