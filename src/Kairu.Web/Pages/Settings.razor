@page "/settings"
@attribute [Authorize]
@using Kairu.Web.Services
@inject PomodoroApiClient PomodoroApi
@inject SettingsApiClient SettingsApi
@inject IJSRuntime JSRuntime
@inject ISoundService SoundService

<h2>⚙ Paramètres</h2>

@if (!_loaded)
{
    <p>Chargement…</p>
}
else
{
    <div style="max-width: 600px">
        <!-- Theme Section -->
        <div class="mb-5">
            <h4>🎨 Thème</h4>
            <div class="mb-3">
                <label class="form-label">Préférence de thème</label>
                <select class="form-select" @bind="_selectedTheme" @bind:after="OnThemeChanged">
                    <option value="Light">☀️ Clair</option>
                    <option value="Dark">🌙 Sombre</option>
                    <option value="System">⚙️ Système</option>
                </select>
                <div class="form-text">Le thème sera appliqué immédiatement et sauvegardé.</div>
            </div>
        </div>

        <!-- Ringtone Section -->
        <div class="mb-5">
            <h4>🔔 Sonnerie Pomodoro</h4>
            <div class="mb-3">
                <label class="form-label">Son de fin de session</label>
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-select" @bind="_selectedRingtone" @bind:after="OnRingtoneChanged">
                        <option value="None">🔇 Aucun son</option>
                        <option value="AlarmClock">⏰ Réveil</option>
                        <option value="Bird">🐦 Oiseau</option>
                    </select>
                    <button type="button" class="btn btn-outline-secondary" @onclick="PreviewRingtone"
                            disabled="@(_selectedRingtone == "None")">
                        ▶ Tester
                    </button>
                </div>
                <div class="form-text">Joué automatiquement à la fin de chaque sprint ou pause.</div>
            </div>
        </div>

        <!-- API Key Section -->
        <hr class="my-4" />
        <div class="mb-5">
            <h4>🔑 Clé API (MCP)</h4>
            <p class="text-body-secondary">Utilisée par les clients IA (Claude Code, Codex…) pour accéder à Kairu via le protocole MCP.</p>

            @if (_apiKeyLoading)
            {
                <p>Chargement…</p>
            }
            else if (_apiKeyToken is not null)
            {
                <div class="alert alert-warning">
                    <strong>⚠ Copiez ce token maintenant — il ne sera plus affiché.</strong>
                    <div class="d-flex gap-2 align-items-center mt-2">
                        <code class="flex-grow-1 user-select-all p-2 bg-body-tertiary rounded" style="word-break: break-all;">@_apiKeyToken</code>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CopyToken" title="Copier">
                            @(_copied ? "✓ Copié" : "📋 Copier")
                        </button>
                    </div>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="DismissToken">
                    J'ai copié mon token
                </button>
            }
            else
            {
                @if (_apiKeyExists)
                {
                    <div class="mb-3">
                        <span class="badge bg-success me-2">● Active</span>
                        @if (_apiKeyCreatedAt.HasValue)
                        {
                            <span class="text-body-secondary small">Générée le @_apiKeyCreatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        }
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <span class="badge bg-secondary me-2">● Aucune clé</span>
                    </div>
                }

                @if (_apiKeyError is not null)
                {
                    <div class="alert alert-danger">⚠ @_apiKeyError</div>
                }

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-primary" @onclick="GenerateApiKey" disabled="@_apiKeyBusy">
                        @(_apiKeyBusy ? "Génération…" : (_apiKeyExists ? "Régénérer" : "Générer une clé"))
                    </button>
                    @if (_apiKeyExists)
                    {
                        <button type="button" class="btn btn-outline-danger" @onclick="RevokeApiKey" disabled="@_apiKeyBusy">
                            Révoquer
                        </button>
                    }
                </div>
            }
        </div>

        <hr class="my-4" />
        <h4>Pomodoro</h4>
        <EditForm Model="_form" OnValidSubmit="SavePomodoroSettings">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Durée du sprint (minutes)</label>
                <input type="number" class="form-control" @bind="_form.SprintDuration" min="1" max="120" />
                <div class="form-text">Entre 1 et 120 minutes. Valeur par défaut : 25 minutes.</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Durée de la pause courte (minutes)</label>
                <input type="number" class="form-control" @bind="_form.ShortBreakDuration" min="1" max="120" />
                <div class="form-text">Entre 1 et 120 minutes. Valeur par défaut : 5 minutes.</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Durée de la pause longue (minutes)</label>
                <input type="number" class="form-control" @bind="_form.LongBreakDuration" min="1" max="120" />
                <div class="form-text">Entre 1 et 120 minutes. Valeur par défaut : 15 minutes.</div>
            </div>

            <div class="alert alert-info">
                <strong>ℹ️ Rappel :</strong> Une pause longue est recommandée tous les 4 sprints.
            </div>

            @if (_successMessage is not null)
            {
                <div class="alert alert-success">
                    ✓ @_successMessage
                </div>
            }

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger">
                    ⚠ @_errorMessage
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @(_saving ? "Enregistrement…" : "Enregistrer")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ResetToDefaults" disabled="@_saving">
                    Réinitialiser
                </button>
            </div>
        </EditForm>
    </div>
}

@code {
    private bool _loaded;
    private bool _saving;
    private string? _successMessage;
    private string? _errorMessage;
    private SettingsForm _form = new();
    private string _selectedTheme = "System";
    private string _selectedRingtone = "AlarmClock";

    // API Key state — token kept only in component RAM, never persisted
    private bool _apiKeyLoading;
    private bool _apiKeyBusy;
    private bool _apiKeyExists;
    private DateTime? _apiKeyCreatedAt;
    private string? _apiKeyToken;
    private string? _apiKeyError;
    private bool _copied;

    private sealed class SettingsForm
    {
        public int SprintDuration { get; set; } = 25;
        public int ShortBreakDuration { get; set; } = 5;
        public int LongBreakDuration { get; set; } = 15;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load Pomodoro settings
        var pomodoroSettings = await PomodoroApi.GetSettingsAsync();
        if (pomodoroSettings is not null)
        {
            _form.SprintDuration = pomodoroSettings.SprintDurationMinutes;
            _form.ShortBreakDuration = pomodoroSettings.ShortBreakDurationMinutes;
            _form.LongBreakDuration = pomodoroSettings.LongBreakDurationMinutes;
        }

        // Load theme preference
        var userSettings = await SettingsApi.GetSettingsAsync();
        if (userSettings is not null)
        {
            _selectedTheme = userSettings.ThemePreference;
            _selectedRingtone = userSettings.RingtonePreference;
            await ApplyTheme(_selectedTheme);
        }

        await LoadApiKeyStatusAsync();

        _loaded = true;
    }

    private async Task LoadApiKeyStatusAsync()
    {
        _apiKeyLoading = true;
        var status = await SettingsApi.GetApiKeyStatusAsync();
        if (status is not null)
        {
            _apiKeyExists = status.Exists;
            _apiKeyCreatedAt = status.CreatedAt;
        }
        _apiKeyLoading = false;
    }

    private async Task GenerateApiKey()
    {
        _apiKeyBusy = true;
        _apiKeyError = null;
        _copied = false;
        var result = await SettingsApi.GenerateApiKeyAsync();
        if (result is not null)
        {
            _apiKeyToken = result.Token;
            _apiKeyExists = true;
            _apiKeyCreatedAt = DateTime.UtcNow;
        }
        else
        {
            _apiKeyError = "Impossible de générer la clé API.";
        }
        _apiKeyBusy = false;
    }

    private async Task RevokeApiKey()
    {
        _apiKeyBusy = true;
        _apiKeyError = null;
        var success = await SettingsApi.RevokeApiKeyAsync();
        if (success)
        {
            _apiKeyExists = false;
            _apiKeyCreatedAt = null;
            _apiKeyToken = null;
        }
        else
        {
            _apiKeyError = "Impossible de révoquer la clé API.";
        }
        _apiKeyBusy = false;
    }

    private async Task CopyToken()
    {
        if (_apiKeyToken is null) return;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _apiKeyToken);
        _copied = true;
    }

    private void DismissToken()
    {
        _apiKeyToken = null;
        _copied = false;
    }

    private async Task OnThemeChanged()
    {
        await ApplyTheme(_selectedTheme);
        await SettingsApi.SaveThemePreferenceAsync(_selectedTheme);
    }

    private async Task OnRingtoneChanged()
    {
        await SettingsApi.SaveRingtonePreferenceAsync(_selectedRingtone);
    }

    private async Task PreviewRingtone()
    {
        await SoundService.PlayRingtoneAsync(_selectedRingtone);
    }

    private async Task ApplyTheme(string theme)
    {
        var effectiveTheme = theme;

        if (theme == "System")
        {
            var isDark = await JSRuntime.InvokeAsync<bool>("eval", "window.matchMedia('(prefers-color-scheme: dark)').matches");
            effectiveTheme = isDark ? "Dark" : "Light";
        }

        await JSRuntime.InvokeVoidAsync("eval", 
            effectiveTheme == "Dark" 
                ? "document.documentElement.setAttribute('data-bs-theme', 'dark')" 
                : "document.documentElement.setAttribute('data-bs-theme', 'light')");
    }

    private async Task SavePomodoroSettings()
    {
        _saving = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            if (_form.SprintDuration < 1 || _form.SprintDuration > 120)
            {
                _errorMessage = "La durée du sprint doit être entre 1 et 120 minutes.";
                return;
            }

            if (_form.ShortBreakDuration < 1 || _form.ShortBreakDuration > 120)
            {
                _errorMessage = "La durée de la pause courte doit être entre 1 et 120 minutes.";
                return;
            }

            if (_form.LongBreakDuration < 1 || _form.LongBreakDuration > 120)
            {
                _errorMessage = "La durée de la pause longue doit être entre 1 et 120 minutes.";
                return;
            }

            var success = await PomodoroApi.SaveSettingsAsync(
                _form.SprintDuration,
                _form.ShortBreakDuration,
                _form.LongBreakDuration);

            if (success)
            {
                _successMessage = "Paramètres enregistrés avec succès !";
            }
            else
            {
                _errorMessage = "Impossible d'enregistrer les paramètres. Vérifiez les valeurs saisies.";
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void ResetToDefaults()
    {
        _form.SprintDuration = 25;
        _form.ShortBreakDuration = 5;
        _form.LongBreakDuration = 15;
        _successMessage = null;
        _errorMessage = null;
    }
}
