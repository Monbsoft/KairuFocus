{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "AppHost (Aspire)",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/KairuFocus.AppHost/KairuFocus.AppHost.csproj", "--launch-profile", "http"],
      "port": 15100
    },
    {
      "name": "API",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/KairuFocus.Api/KairuFocus.Api.csproj", "--launch-profile", "http"],
      "port": 5205
    },
    {
      "name": "Web (Blazor WASM)",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/KairuFocus.Web/KairuFocus.Web.csproj", "--launch-profile", "http"],
      "port": 5010
    }
  ]
}
